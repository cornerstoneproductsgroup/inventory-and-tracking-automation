RITHUM_URL=https://dsm.commercehub.com/dsm/gotoHome.do
RITHUM_USERNAME=your-rithum-email@example.com
RITHUM_PASSWORD=your-rithum-password

SPS_URL=https://commerce.spscommerce.com
SPS_USERNAME=your-sps-email@example.com
SPS_PASSWORD=your-sps-password
# SPS-only steps (menu 7 / 9 / B) need only SPS_* above. CommerceHub steps also need RITHUM_*.
# UPS tracking CSV for Depot, Tractor Supply, and Grainger (WorldShip export):
# UPS_TRACKING_CSV_PATH=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\z - UPS Tracking\UPS_CSV_EXPORT.csv

HEADLESS=false
TIMEOUT_MS=30000

# CommerceHub chain (menu 1 / commercehub_chain) — poll until UI is ready; higher ceilings for slow loads.
# Still proceeds as soon as controls appear (COMMERCEHUB_POLL_INTERVAL_MS between checks).
# COMMERCEHUB_DEFAULT_TIMEOUT_MS=120000
# COMMERCEHUB_NAVIGATION_TIMEOUT_MS=180000
# COMMERCEHUB_IBL_TIMEOUT_MS=90000
# COMMERCEHUB_PROFILE_TIMEOUT_MS=30000
# COMMERCEHUB_LOGIN_PROBE_TIMEOUT_MS=20000
# COMMERCEHUB_POLL_INTERVAL_MS=400
# DEPOT_SHIP_LIST_TIMEOUT_MS=300000
# DEPOT_INVOICE_READY_TIMEOUT_MS=240000
# DEPOT_QUEUE_PROBE_TIMEOUT_MS=60000
# LOWES_ORDER_LINKS_TIMEOUT_MS=60000
# LOWES_PO_ROW_TIMEOUT_MS=45000
# LOWES_INVOICE_SELECT_TIMEOUT_MS=90000

# Pull Orders (menu 0) — browser (Edge on Windows; login same as tracking/inventory)
# CommerceHub: RITHUM_USERNAME / RITHUM_PASSWORD / RITHUM_URL above (not config.json passwords)
# SPS: SPS_USERNAME / SPS_PASSWORD above + sps_playwright_storage.json (shared with tracking)
# PULL_ORDERS_BROWSER_CHANNEL=msedge
# Optional separate Edge profiles (default off — uses .env login + sps_playwright_storage.json):
# PULL_ORDERS_COMMERCEHUB_USE_PERSISTENT_PROFILE=0
# PULL_ORDERS_SPS_USE_PERSISTENT_PROFILE=0
# PULL_ORDERS_COMMERCEHUB_USER_DATA_DIR=pull_orders_commercehub_profile
# PULL_ORDERS_SPS_USER_DATA_DIR=pull_orders_sps_profile

# Pull Orders (menu 0) — optional timing
# PULL_ORDERS_POST_DOWNLOAD_WAIT_S=60
# PULL_ORDERS_WAREHOUSE_WAIT_MINUTES=60
# PULL_ORDERS_WAREHOUSE_POLL_S=15

# FedEx batch shipping (menu F / run_fedex_batch.py) — required for auto-login only
FEDEX_USERNAME=your-fedex-login@example.com
FEDEX_PASSWORD=your-fedex-password
# Manual sign-in (you type credentials in browser; not required for --login-test / --manual-login):
# Run FedEx Manual Login.bat  OR  python run_fedex_batch.py --login-test
# FEDEX_MANUAL_LOGIN=1
# FEDEX_SKIP_AUTO_LOGIN=1
# FedEx blocks Playwright Chromium — use installed Edge/Chrome + persistent profile (defaults on Windows):
# FEDEX_BROWSER_CHANNEL=msedge
# FEDEX_USE_PERSISTENT_PROFILE=1
# FEDEX_USER_DATA_DIR=fedex_browser_profile
# FEDEX_BROWSER_CHANNEL=chromium
# FEDEX_USE_PERSISTENT_PROFILE=0
# FEDEX_BATCH_URL=https://www.fedex.com/shippingplus/en-us/shipments-import
# FEDEX_LOWES_CSV_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\CSV File Output\Lowe's
# FEDEX_LOWES_LABELS_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\3-Lowe's\1-Fedex Shipping Labels
# FEDEX_LOWES_CSV_PATH=
# FEDEX_UPLOAD_POLL_TIMEOUT_S=600
# FEDEX_UPLOAD_POLL_INTERVAL_S=10
# Extra seconds per shipment while FedEx processes upload (large batches need more):
# FEDEX_UPLOAD_POLL_PER_SHIPMENT_S=6
# FEDEX_LOWES_TRACKING_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\z - Lowe's Tracking
# FEDEX_LOWES_MASTER_BASENAME=Lowe's Fedex Master
# FEDEX_SHIPMENT_REPORT_TIMEOUT_MS=180000
# FedEx Zebra warehouse vendors: Order Splitter watcher.py if installed, else warehouse_vendors.json in this folder
# ORDER_SPLITTER_V2_DIR=C:\OrderSplitter\Order-Splitter-v2
# FEDEX_WAREHOUSE_VENDORS_FILE=\\rygarcorp.com\shares\Cornerstone\Automation\Vendor Maps for SKUs\warehouse_vendors.json
# Warehouse FedEx labels — exact Zebra name from Windows Printers (required on FedEx PC):
# FEDEX_WAREHOUSE_LABEL_PRINTER=Zebra ZP 450-200 dpi
# Fallback if unset: PULL_ORDERS_SOS_LABEL_PRINTER, then PULL_ORDERS_LABEL_PRINTER, then auto-detect Zebra.
# Warehouse labels: save PDF to queue folder, background watcher prints (default queue).
# Set edge to use legacy in-browser Edge print UI instead:
# FEDEX_WAREHOUSE_LABEL_PRINT_MODE=queue
# FEDEX_WAREHOUSE_LABEL_QUEUE_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\3-Lowe's\1-Fedex Shipping Labels\z - Warehouse Print Queue
# FEDEX_WAREHOUSE_WATCH_POLL_S=2
# FEDEX_WAREHOUSE_WATCH_DRAIN_TIMEOUT_S=600
# Legacy edge mode only — pause on label tab before Edge print (ms):
# FEDEX_WAREHOUSE_PRINT_PAUSE_MS=4000
# FEDEX_WAREHOUSE_AFTER_PRINT_MS=6000
# Pause after checking shipment rows before clicking Finalize (default 2000 ms):
# FEDEX_AFTER_ROW_SELECT_MS=2500
# FedEx login pacing (ms):
# FEDEX_INITIAL_WAIT_MS=1200
# FEDEX_AFTER_COOKIE_MS=600
# FEDEX_MICRO_PAUSE_MS=350
# Copy fedex_batch.example.json to fedex_batch.json for selector tweaks.

# Scheduled morning workflow (Install-Morning-Schedule-Task.bat)
# SCHEDULED_WORKFLOW_TIME=05:00
# SCHEDULED_WORKFLOW_CONFIG=scheduled_workflow.json

# UPS.com batch file shipping (menu W — Depot, Special Order, Tractor; up to 250 shipments)
# Copy ups_batch.example.json to ups_batch.json for selector tweaks.
#
# Recommended: auto-login + isolated browser profile (Huntress-safe)
# UPS_USERNAME=your-ups-login
# UPS_PASSWORD=your-ups-password
# UPS_BROWSER_MODE=dedicated
# UPS_BROWSER_CHANNEL=msedge
# Do NOT set UPS_SKIP_AUTO_LOGIN=1 (that blocks auto-login)
# Verify: python run_ups_online_batch.py --check-credentials
#
# CDP against real Chrome/Edge profile is DISABLED (Huntress flags it as infostealer).
# UPS_KILL_CHROME=1
# UPS_MANUAL_LOGIN=0
# UPS_USE_PERSISTENT_PROFILE=1
# UPS_USER_DATA_DIR=ups_browser_profile
# UPS_HOME_URL=https://www.ups.com/us/en/home
# UPS_LOGIN_URL=https://www.ups.com/lasso/login?loc=en_US&returnto=https%3A%2F%2Fwww.ups.com%2Fus%2Fen%2Fhome
# UPS_BATCH_LANE=depot
# UPS_DEPOT_CSV_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\CSV File Output\Depot
# UPS_DEPOT_CSV_PATH=
# UPS_DEPOT_LABELS_MAIN_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\2-Home Depot\1 - UPS Shipping Labels\1 - Main File For The Day
# UPS_THDSO_CSV_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\CSV File Output\Depot Special Order
# UPS_THDSO_CSV_PATH=
# UPS_THDSO_LABELS_MAIN_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\12-Depot Special Orders\1 - UPS Shipping Labels\1 - Main File For The Day
# UPS_TRACTOR_CSV_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\CSV File Output\Tractor Supply
# UPS_TRACTOR_CSV_PATH=
# UPS_TRACTOR_LABELS_MAIN_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\6-Tractor Supply\1 - UPS Shipping Labels\1 - Main File For The Day
# UPS_LABEL_SAVE_TIMEOUT_S=180
# UPS_VERIFY_WAIT_MS=8000
# UPS_POPUP_WAIT_MS=1800
# UPS_POPUP_DISMISS_ROUNDS=4
