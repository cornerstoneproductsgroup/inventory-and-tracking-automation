RITHUM_URL=https://dsm.commercehub.com/dsm/gotoHome.do
RITHUM_USERNAME=your-rithum-email@example.com
RITHUM_PASSWORD=your-rithum-password

SPS_URL=https://commerce.spscommerce.com
SPS_USERNAME=your-sps-email@example.com
SPS_PASSWORD=your-sps-password
# SPS-only steps (menu 7 / 9 / B) need only SPS_* above. CommerceHub steps also need RITHUM_*.

HEADLESS=false
TIMEOUT_MS=30000

# UPS WorldShip desktop app (menu W — WorldShip Batch Import)
# Easiest: pin UPS WorldShip to the Windows taskbar on each PC (no path needed).
# Optional override if taskbar detection fails on a machine:
# Optional timing (seconds) — cold start is ~40s to OK dialog, then ~2 min to load:
# WORLDSHIP_OK_DIALOG_TIMEOUT_S=90
# WORLDSHIP_READY_TIMEOUT_S=300
# WORLDSHIP_BEFORE_CHECKBOX_WAIT_S=2
# WORLDSHIP_BEFORE_NEXT_WAIT_S=1
# Use uia backend only (default) — win32 can cause Access denied while WorldShip loads.
# WORLDSHIP_UI_BACKEND=uia
#
# Label saves after Import/Export Preview (CornerstoneMaster + vendor maps on share):
# WORLDSHIP_VENDOR_MAP_DIR=\\rygarcorp.com\shares\Cornerstone\Automation\Vendor Maps for SKUs
# WORLDSHIP_CORNERSTONE_MASTER_DIR=\\svr01\Cornerstone\Dot Com Packing Slips\zzz - Worldship Shipment Files\Cornerstone
# WORLDSHIP_LABEL_EXT=.gif
# WORLDSHIP_FIRST_SAVE_TIMEOUT_S=180
# WORLDSHIP_SAVE_TIMEOUT_S=90
