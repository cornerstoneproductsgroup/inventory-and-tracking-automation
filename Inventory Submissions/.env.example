RITHUM_URL=https://dsm.commercehub.com/dsm/gotoHome.do
RITHUM_USERNAME=your-rithum-email@example.com
RITHUM_PASSWORD=your-rithum-password

SPS_URL=https://commerce.spscommerce.com
SPS_USERNAME=your-sps-email@example.com
SPS_PASSWORD=your-sps-password
# SPS-only steps (menu 7 / 9 / B) need only SPS_* above. CommerceHub steps also need RITHUM_*.

HEADLESS=false
TIMEOUT_MS=30000

# CommerceHub chain (menu 1 / commercehub_chain) — poll until UI is ready; higher ceilings for slow loads.
# Still proceeds as soon as controls appear (COMMERCEHUB_POLL_INTERVAL_MS between checks).
# COMMERCEHUB_DEFAULT_TIMEOUT_MS=120000
# COMMERCEHUB_NAVIGATION_TIMEOUT_MS=180000
# COMMERCEHUB_IBL_TIMEOUT_MS=90000
# COMMERCEHUB_PROFILE_TIMEOUT_MS=30000
# COMMERCEHUB_LOGIN_PROBE_TIMEOUT_MS=20000
# COMMERCEHUB_POLL_INTERVAL_MS=400
# DEPOT_SHIP_LIST_TIMEOUT_MS=300000
# DEPOT_INVOICE_READY_TIMEOUT_MS=240000
# DEPOT_QUEUE_PROBE_TIMEOUT_MS=60000
# LOWES_ORDER_LINKS_TIMEOUT_MS=60000
# LOWES_PO_ROW_TIMEOUT_MS=45000
# LOWES_INVOICE_SELECT_TIMEOUT_MS=90000

# Pull Orders (menu 0) — optional timing
# PULL_ORDERS_POST_DOWNLOAD_WAIT_S=60
# PULL_ORDERS_WAREHOUSE_WAIT_MINUTES=60
# PULL_ORDERS_WAREHOUSE_POLL_S=15

# FedEx batch shipping (menu F / run_fedex_batch.py) — required for login
FEDEX_USERNAME=your-fedex-login@example.com
FEDEX_PASSWORD=your-fedex-password
# FEDEX_MANUAL_LOGIN=1
# FEDEX_SKIP_AUTO_LOGIN=1
# FEDEX_BATCH_URL=https://www.fedex.com/shippingplus/en-us/shipments-import
# FEDEX_LOWES_CSV_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\CSV File Output\Lowe's
# FEDEX_LOWES_LABELS_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\3-Lowe's\1-Fedex Shipping Labels
# FEDEX_LOWES_CSV_PATH=
# FEDEX_UPLOAD_POLL_TIMEOUT_S=600
# FEDEX_LOWES_TRACKING_DIR=\\rygarcorp.com\shares\Cornerstone\Dot Com Packing Slips\1-Orders Before Extraction\Order Splitter Output\z - Lowe's Tracking
# FEDEX_LOWES_MASTER_BASENAME=Lowe's Fedex Master
# FEDEX_SHIPMENT_REPORT_TIMEOUT_MS=180000
# FedEx Zebra warehouse vendors: Order Splitter watcher.py if installed, else warehouse_vendors.json in this folder
# ORDER_SPLITTER_V2_DIR=C:\OrderSplitter\Order-Splitter-v2
# FEDEX_WAREHOUSE_VENDORS_FILE=\\rygarcorp.com\shares\Cornerstone\Automation\Vendor Maps for SKUs\warehouse_vendors.json
# FEDEX_WAREHOUSE_LABEL_PRINTER=Zebra ZP 450
# Pause after checking shipment rows before clicking Finalize (default 2000 ms):
# FEDEX_AFTER_ROW_SELECT_MS=2500
# FedEx login pacing (ms):
# FEDEX_INITIAL_WAIT_MS=1200
# FEDEX_AFTER_COOKIE_MS=600
# FEDEX_MICRO_PAUSE_MS=350
# Copy fedex_batch.example.json to fedex_batch.json for selector tweaks.

# Scheduled morning workflow (Install-Morning-Schedule-Task.bat)
# SCHEDULED_WORKFLOW_TIME=05:00
# SCHEDULED_WORKFLOW_CONFIG=scheduled_workflow.json

# UPS WorldShip desktop app (menu W — WorldShip Batch Import)
# Easiest: pin UPS WorldShip to the Windows taskbar on each PC (no path needed).
# Optional override if taskbar detection fails on a machine:
# Optional timing (seconds) — cold start is ~40s to OK dialog, then ~2 min to load:
# WORLDSHIP_OK_DIALOG_TIMEOUT_S=90
# WORLDSHIP_READY_TIMEOUT_S=300
# WORLDSHIP_WARM_READY_TIMEOUT_S=12
# WORLDSHIP_AFTER_TAB_S=0.35
# WORLDSHIP_BEFORE_NEXT_WAIT_S=1.5
# WORLDSHIP_PREVIEW_BEFORE_NEXT_S=0.25
# WORLDSHIP_AFTER_PREVIEW_NEXT_S=2.0
# Use uia backend only (default) — win32 can cause Access denied while WorldShip loads.
# WORLDSHIP_UI_BACKEND=uia
#
# Label saves after Import/Export Preview (CornerstoneMaster + vendor maps on share):
# WORLDSHIP_VENDOR_MAP_DIR=\\rygarcorp.com\shares\Cornerstone\Automation\Vendor Maps for SKUs
# WORLDSHIP_CORNERSTONE_MASTER_DIR=\\svr01\Cornerstone\Dot Com Packing Slips\zzz - Worldship Shipment Files\Cornerstone
# WORLDSHIP_LABEL_EXT=.pdf
# WORLDSHIP_SMART_PICKUP_WAIT_S=8
# WORLDSHIP_PROCESSING_TIMEOUT_S=600
# WORLDSHIP_PROCESSING_PER_ORDER_S=45
# WORLDSHIP_FIRST_SAVE_TIMEOUT_S=180
# WORLDSHIP_SAVE_TIMEOUT_S=90
# Seconds to wait after each label save before the next Save dialog (default 4):
# WORLDSHIP_SAVE_BETWEEN_LABELS_S=2
# WORLDSHIP_MIN_LABEL_BYTES=800
# WORLDSHIP_SAVE_AFTER_FOLDER_S=1.0
# WORLDSHIP_SAVE_FILENAME_ATTEMPTS=3
# WORLDSHIP_SAVE_FOLDER_NAV_S=1.2
# WORLDSHIP_SAVE_FILENAME_SETTLE_S=0.35
# WORLDSHIP_SAVE_BEFORE_CLICK_S=0.35
# Seconds to wait after pasting folder path in Save Print Output (default 1.4):
# WORLDSHIP_SAVE_FOLDER_NAV_S=2
# Seconds to wait for warehouse-print rows (no Save dialog expected; default 15):
# WORLDSHIP_PRINT_WAIT_S=15
# WORLDSHIP_PRINT_COMPLETE_TIMEOUT_S=2400
# WORLDSHIP_PRINT_COMPLETE_PER_LABEL_S=8
# WORLDSHIP_END_OF_DAY_TIMEOUT_S=900
# WORLDSHIP_BATCH_EXPORT_TIMEOUT_S=600
# WORLDSHIP_AFTER_CLOSE_SETTLE_S=2
# WORLDSHIP_LOAD_NUDGE_CLICKS=2
