{
  "browser": {
    "headless": false,
    "slow_mo_ms": 80,
    "default_timeout_ms": 120000
  },
  "fedex": {
    "login_url": "https://www.fedex.com/secure-login/en-us/",
    "batch_url": "https://www.fedex.com/shippingplus/en-us/shipments-import",
    "username": "${FEDEX_USERNAME}",
    "password": "${FEDEX_PASSWORD}"
  },
  "selectors": {
    "username_input": "#username, input#username[autocomplete='username'], input[name='username']",
    "password_input": "#password, input#password[type='password'], input[name='password']",
    "login_submit": "button:has-text('Log In'), button:has-text('LOG IN'), button:has-text('Sign in'), button.fdx-c-button:has-text('Log In')",
    "cookie_accept": "#onetrust-accept-btn-handler, button#onetrust-accept-btn-handler, button:has-text('Accept all cookies')",
    "upload_button": "[data-test-id=\"files-upload-btn\"]",
    "file_input": "#uploadFileInput-GENERAL, input[type='file']",
    "start_upload_button": "button:has-text('Start upload'), .fdx-c-button__title:has-text('Start upload')",
    "shipment_table_row": "table tbody tr.mat-mdc-row, tr.mat-mdc-row",
    "row_checkbox": "input[type='checkbox']",
    "clear_selection_button": "button:has-text('CLEAR SELECTION')",
    "finalize_toolbar": "button.fdx-c-button:has(span.fdx-c-button__title:text-matches('Finalize', 'i'))",
    "finalize_print_manual": "span.mat-mdc-menu-item-text:text-matches('Finalize and print manually', 'i')",
    "select_all_checkbox": "thead label.fdx-c-form-group__label[data-test-id='label'], thead label[for^='fedex-checkbox-']",
    "download_button": "button:has-text('DOWNLOAD'), a:has-text('DOWNLOAD')",
    "shipment_report_menu": "span.mat-mdc-menu-item-text:has-text('Shipment report (.xlsx file)')",
    "load_retry_button": "button:has-text('Retry'), .fdx-c-button:has-text('Retry')"
  },
  "label_save": {
    "use_native_save_dialog": true,
    "pause_between_labels_ms": 1000
  },
  "timing": {
    "after_row_select_ms": 2000,
    "initial_wait_ms": 1200,
    "after_cookie_accept_ms": 600,
    "micro_pause_ms": 350
  }
}
