# Copy to .env next to commercehub_invoice_export.py (same folder). Never commit .env.
# This project always loads that file — not "current folder" — so shortcuts and Task Scheduler still find secrets.

COMMERCEHUB_USERNAME=you@company.com
COMMERCEHUB_PASSWORD=your_password

# Profile picker: substring match on link text (case-insensitive), or use URL below.
COMMERCEHUB_PROFILE_TEXT=Cornerstone Products Group

# Recommended if the chooser closes or text does not match: copy the profile link from the picker.
# COMMERCEHUB_PROFILE_URL=https://dsm.commercehub.com/dsm/handleLogin.do?identityKey=YOUR-GUID

# Depot: after download, build formatted xlsx on the share (filename uses report date, e.g. 5-12-2026).
# COMMERCEHUB_DEPOT_POSTPROCESS=true
# COMMERCEHUB_DEPOT_OUTPUT_DIR=\\rygarcorp.com\shares\Cornerstone\Invoice Reports\Depot
# COMMERCEHUB_ACCOUNTING_NUMBER_FORMAT=_("$"* #,##0.00_);_("$"* \(#,##0.00\);_("$"* "-"??_);_(@_)

# Invoicing menu (interactive when you run the script, unless CLI / env below is set):
#   1 = All (parallel: CH Depot+Lowe's + SPS Tractor), 2 = Depot, 3 = Lowe's, 4 = Tractor (SPS), 5 = Depot+Lowe's CH only.
# Task Scheduler / silent: COMMERCEHUB_MENU_CHOICE=1
# COMMERCEHUB_MENU_CHOICE=

# Lowe's: same-session flow after Depot when you pick "1" or "3" (COMMERCEHUB_RUN_LOWE is no longer used by the menu).
# COMMERCEHUB_RUN_LOWE=true
# COMMERCEHUB_LOWE_POSTPROCESS=true
# COMMERCEHUB_LOWE_OUTPUT_DIR=\\rygarcorp.com\shares\Cornerstone\Invoice Reports\Lowe's
# Optional: override saved-search execute URL if CommerceHub id changes
# COMMERCEHUB_LOWE_SAVED_SEARCH_URL=https://dsm.commercehub.com/dsm/executeSavedSearch.do?standard=false&name=...&id=...
# Optional: saved-search list label if you land on the list instead of criteria (default: Lowe's Invoice Batch Print by Date)
# COMMERCEHUB_LOWE_SAVED_SEARCH_NAME=Lowe's Invoice Batch Print by Date
#
# Tractor Supply (SPS Commerce bulk CSV)
# COMMERCEHUB_TRACTOR_OUTPUT_DIR=\\rygarcorp.com\shares\Cornerstone\Invoice Reports\Tractor Supply

# Excel COM print after each formatted xlsx is saved (Windows + Excel + pywin32). Set false to skip.
# COMMERCEHUB_EXCEL_PRINT=true
# Paste exact string from Excel VBA: ?Application.ActivePrinter (includes " on Ne..:" port)
# COMMERCEHUB_EXCEL_PRINTER=\\SVR01A\Toshiba e-STUDIO3515AC on Ne04:
# If COMMERCEHUB_EXCEL_PRINTER is unset, looks for a printer name containing 3515 and SVR01A.

# Optional: open criteria page directly if menu navigation does not land on the invoice search
# COMMERCEHUB_ORDER_SEARCH_URL=https://dsm.commercehub.com/dsm/...

# Saved search list (after Orders → Search): exact or unique substring of the row title (case-insensitive).
# Default if unset: Home Depot Invoice Batch Print by Date
# COMMERCEHUB_SAVED_SEARCH_NAME=Home Depot Invoice Batch Print by Date
# Set to empty in .env to skip: COMMERCEHUB_SAVED_SEARCH_NAME=
# Or skip explicitly: COMMERCEHUB_SKIP_SAVED_SEARCH_LIST=true
# Optional: extra ms to wait for the list to render before clicking (default 3500)
# COMMERCEHUB_SAVED_SEARCH_LIST_SETTLE_MS=5000

# Where to save the exported file (directory must exist)
COMMERCEHUB_DOWNLOAD_DIR=./downloads

# If the share denies write (workbook open in Excel, or scheduled task user lacks ACL), save the formatted xlsx here.
# COMMERCEHUB_OUTPUT_FALLBACK_DIR=./downloads/processed

# Optional: timeouts in milliseconds (defaults are longer for slow Rithum days).
# COMMERCEHUB_NAV_TIMEOUT_MS=300000
# COMMERCEHUB_STEP_TIMEOUT_MS=240000
# COMMERCEHUB_LOGIN_TIMEOUT_MS=240000
# COMMERCEHUB_DOWNLOAD_TIMEOUT_MS=900000

# Optional: run browser visibly for debugging (true/false)
COMMERCEHUB_HEADLESS=true

# --- SPS Commerce (Tractor Supply) when you pick "1" or "4" ---
# Uses the same keys as "Depot and Lowe's Automation with Inventory Feed / Inventory Submissions/.env":
#   SPS_URL, SPS_USERNAME, SPS_PASSWORD  (optional: TIMEOUT_MS or SPS_TIMEOUT_MS for login field waits)
# By default this project also loads that .env (without overriding variables already set here).
# COMMERCEHUB_RUN_SPS_TRACTOR is unused by the menu script; use menu option 4 or "1" for All.
# Override path to the Inventory Feed .env if yours is elsewhere:
# COMMERCEHUB_SPS_DOTENV=C:\Chat GPT Automation\Depot and Lowe's Automation with Inventory Feed\Inventory Submissions\.env
