{
  "schedule": {
    "time_local": "05:00",
    "task_name": "Cornerstone Morning Automation"
  },
  "settings": {
    "log_dir": "logs",
    "log_basename": "scheduled_workflow.log"
  },
  "steps": [
    {
      "id": "pull_orders",
      "label": "Pull Orders — CommerceHub PDF/CSV, SPS, warehouse print",
      "enabled": true,
      "continue_on_error": false,
      "type": "workflow",
      "args": ["--pull-orders-only"]
    },
    {
      "id": "fedex_batch",
      "label": "FedEx Batch — upload Lowe's CSV, finalize, labels, shipment report",
      "enabled": true,
      "continue_on_error": false,
      "type": "workflow",
      "args": ["--fedex-batch-only"]
    },
    {
      "id": "invoice_reports",
      "label": "All Invoice Reports — Depot, Lowe's, Tractor Supply",
      "enabled": true,
      "continue_on_error": true,
      "type": "workflow",
      "args": ["--invoice-report-only", "--invoice-report-modes", "all"]
    },
    {
      "id": "inventories",
      "label": "All Inventories — CommerceHub Rithum + SPS Tractor Supply",
      "enabled": true,
      "continue_on_error": true,
      "type": "workflow",
      "args": [
        "--skip-invoice-report",
        "--skip-sps-tracking",
        "--skip-depot",
        "--skip-lowes"
      ]
    }
  ],
  "_on_hold_steps": [
    {
      "id": "amazon_seller_download",
      "label": "Amazon Seller — Deferred Transaction CSV to Input share",
      "enabled": false,
      "on_hold_reason": "Seller Central requires phone 2FA on every fresh Playwright session. Re-enable when manual OTP or persistent browser profile is wired up.",
      "continue_on_error": true,
      "type": "workflow",
      "args": ["--amazon-seller-download-only"],
      "reenable": "Set AMAZON_SELLER_DOWNLOAD_ENABLED=true in invoice report/.env and move this block back into steps[]"
    }
  ],
  "_future_steps_examples": [
    {
      "id": "worldship_import",
      "label": "WorldShip Batch Import — CornerstoneMaster labels",
      "enabled": false,
      "continue_on_error": true,
      "type": "workflow",
      "args": ["--worldship-import-only"]
    },
    {
      "id": "ups_online_batch",
      "label": "UPS Online Batch — Depot / Special Order / Tractor CSV upload + labels",
      "enabled": false,
      "continue_on_error": true,
      "type": "workflow",
      "args": ["--ups-online-batch-only"]
    },
    {
      "id": "tracking_invoicing",
      "label": "All Tracking and Invoicing",
      "enabled": false,
      "continue_on_error": true,
      "type": "workflow",
      "args": ["--skip-invoice-report", "--tracking-invoicing-only", "--run-grainger-all"]
    }
  ]
}
